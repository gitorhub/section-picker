{
  "manifest_version": 3,
  "name": "Section HTML-CSS Picker",
  "version": "1.0.0",
  "description": "Sayfadan section seç, HTML+CSS al, Tailwind için prompt ile kopyala.",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
